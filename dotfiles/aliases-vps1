# ------------------------------------------------------------------------------
# mac-forge — vps1 SQL snapshot workflow
# Source this file from your shell rc after the main aliases file, e.g.:
#   source ~/mac-forge/dotfiles/aliases-vps1
# ------------------------------------------------------------------------------
alias v1sn="~/mac-forge/scripts/vps1/vps1-db-snapshot.sh"
alias v1r="~/mac-forge/scripts/vps1/vps1-db-restore.sh"
alias v1down="~/mac-forge/scripts/vps1/vps1-db-download.sh"
alias v1up="~/mac-forge/scripts/vps1/vps1-db-upload.sh"
alias rdown-to-v1="~/mac-forge/scripts/vps1/vps1-db-relay-download.sh"
alias v1drop="~/mac-forge/scripts/vps1/vps1-db-drop.sh"
alias v1sndrop="~/mac-forge/scripts/vps1/vps1-db-snapshot-drop.sh"
alias v1am="~/mac-forge/scripts/vps1/vps1-db-migrate.sh"
alias v1list="~/mac-forge/scripts/vps1/vps1-db-list.sh"
alias v1opt="~/mac-forge/scripts/vps1/vps1-db-optimize.sh"
alias v1-bl-publish="~/mac-forge/scripts/vps1/vps1-bl-publish.sh"
alias v1-bl-tunnel-up="~/mac-forge/scripts/vps1/vps1-bl-tunnel.sh up"
alias v1-bl-tunnel-down="~/mac-forge/scripts/vps1/vps1-bl-tunnel.sh down"
alias v1-meerkat-tunnel-up="~/mac-forge/scripts/vps1/vps1-meerkat-tunnel.sh up"
alias v1-meerkat-tunnel-down="~/mac-forge/scripts/vps1/vps1-meerkat-tunnel.sh down"
alias v1-meerkat-tunnel-status="~/mac-forge/scripts/vps1/vps1-meerkat-tunnel.sh status"
alias meerkat-enroll="ssh -t vps1 'sudo meerkat-agent enroll --addr 152.53.45.162:8765'"
alias v1-tally-tunnel-up="~/mac-forge/scripts/vps1/vps1-tally-tunnel.sh up"
alias v1-tally-tunnel-down="~/mac-forge/scripts/vps1/vps1-tally-tunnel.sh down"
alias v1-tally-tunnel-status="~/mac-forge/scripts/vps1/vps1-tally-tunnel.sh status"
alias v1-sql-tunnel-up="~/mac-forge/scripts/vps1/vps1-sql-tunnel.sh up"
alias v1-sql-tunnel-down="~/mac-forge/scripts/vps1/vps1-sql-tunnel.sh down"
alias v1-sql-tunnel-status="~/mac-forge/scripts/vps1/vps1-sql-tunnel.sh status"
alias v1-sql-up="~/mac-forge/scripts/vps1/vps1-db-state.sh online"
alias v1-sql-down="~/mac-forge/scripts/vps1/vps1-db-state.sh offline"

# Long-form equivalents
alias vps1-snapshot=v1sn
alias vps1-restore=v1r
alias vps1-download=v1down
alias vps1-upload=v1up
alias vps1-relay-download=rdown-to-v1
alias vps1-drop=v1drop
alias vps1-snapshot-drop=v1sndrop
alias vps1-migrate=v1am
alias vps1-list=v1list
alias vps1-optimize=v1opt
alias vps1-sql-up=v1-sql-up
alias vps1-sql-down=v1-sql-down
alias vps1-bl-publish=v1-bl-publish
