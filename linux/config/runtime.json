{
  "docker": {
    "container_name": "forge-sql",
    "image": "mcr.microsoft.com/mssql/server:2022-latest",
    "host_port": 2022,
    "sql_user": "sa",
    "container_root": "/var/opt/mssql",
    "container_snapshots_path": "/var/opt/mssql/snapshots",
    "sqlcmd_path": "/opt/mssql-tools18/bin/sqlcmd"
  },
  "paths": {
    "sql_storage_root": "state/mssql",
    "data_bind_path": "data",
    "restore_stage_path": "snapshots"
  }
}
